{
  "expo": {
    "name": "Setter",
    "slug": "setter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "setter",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#A5243D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.setter.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#A5243D"
      },
      "package": "com.setter.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Setter needs access to your photos to read screenshots and documents.",
          "cameraPermission": "Setter needs camera access to snap homework and worksheets."
        }
      ]
    ]
  }
}
